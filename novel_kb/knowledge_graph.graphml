    <edge source="char:燕子澜" target="chap:自动分块_8">
      <data key="d2">约见顾绮尔于云水阁，未参与顾绮尔和太子的对话。</data>
    </edge>
    <edge source="char:燕子澜" target="chap:自动分块_13">
      <data key="d2">{"当前状态": "在云水阁二层与顾绮尔见面，对古乐籍的来源产生怀疑；决定照顾顾绮尔一段时间"}</data>
    </edge>
    <edge source="char:燕子澜" target="chap:自动分块_14">
      <data key="d2">在云水阁二层照顾顾绮尔，对古乐籍来源产生怀疑；得知顾绮尔生病后特意前来慰问。</data>
    </edge>
    <edge source="char:燕子澜" target="chap:自动分块_15">
      <data key="d2">今日身着玄色锦袍，在树林中出现，发现并救下顾绮尔；得知琴贵妃派人调查玉粹阁那位的身份。</data>
    </edge>
    <edge source="char:燕子澜" target="chap:自动分块_16">
      <data key="d2">未直接出场，但通过琴贵妃的行为推测出他可能有目的。</data>
    </edge>
    <edge source="char:燕子澜" target="chap:自动分块_17">
      <data key="d2">{"当前状态": "留宿于偏殿内，并闯入顾绮尔的寝宫，引起顾绮尔的警惕和不满。"}</data>
    </edge>
    <edge source="char:燕子澜" target="chap:自动分块_19">
      <data key="d2">{"当前状态": "被顾绮尔救出山洞后离开，未直接参与后续事件"}</data>
    </edge>
    <edge source="char:燕子澜" target="chap:自动分块_21">
      <data key="d2">同意与顾绮尔结为假夫妻，但对顾绮尔的决定感到意外和欣慰。</data>
    </edge>
    <edge source="char:燕子澜" target="chap:自动分块_22">
      <data key="d2">前来道歉并送礼物给顾绮尔，试图挽回顾绮尔的心。</data>
    </edge>
    <edge source="char:燕子澜" target="chap:自动分块_23">
      <data key="d2">{"当前状态": "与顾绮尔有婚约关系，但态度显得有些奇怪"}</data>
    </edge>
    <edge source="char:燕子澜" target="chap:自动分块_26">
      <data key="d2">继续照顾顾绮尔，并送给她茶叶和书籍。对顾绮尔的行为感到有些无奈，但仍然愿意帮助她弥补。</data>
    </edge>
    <edge source="char:燕子澜" target="chap:自动分块_30">
      <data key="d2">处理了燕康白，并且在顾绮尔的要求下守在门口，等待她换衣服。</data>
    </edge>
    <edge source="char:燕子澜" target="chap:自动分块_34">
      <data key="d2">{"状态": "怜悯顾绮尔，试图安抚她的情绪；位置\": \"在顾绮尔的床边"}</data>
    </edge>
    <edge source="char:燕子澜" target="chap:自动分块_35">
      <data key="d2">{"当前状态": "保护顾绮尔不受傅情威胁，尝试用内力帮助她恢复；神色冷漠"}</data>
    </edge>
    <edge source="char:燕子澜" target="chap:自动分块_36">
      <data key="d2">{"当前状态": "保护顾绮尔不受威胁，试图安抚她的情绪；位置\": \"与顾绮尔同处一室"}</data>
    </edge>
    <edge source="char:燕子澜" target="chap:自动分块_37">
      <data key="d2">{"当前状态": "未出现；位置\": \"未知"}</data>
    </edge>
    <edge source="char:燕子澜" target="chap:自动分块_38">
      <data key="d2">{"当前状态": "未参加晚宴，对顾绮尔询问的下药事件有所回应"}</data>
    </edge>
    <edge source="char:燕子澜" target="chap:自动分块_41">
      <data key="d2">沉默寡言，对顾绮尔的举动反应平静，但因夏日衣裳薄而与顾绮尔亲密接触。</data>
    </edge>
    <edge source="char:燕子澜" target="chap:自动分块_42">
      <data key="d2">在偏殿内处理喜娘失踪一事，对顾绮尔的言行感到不满。</data>
    </edge>
    <edge source="char:燕子澜" target="chap:自动分块_43">
      <data key="d2">拒绝了顾绮尔进入书房的要求，表现出冷漠的态度</data>
    </edge>
    <edge source="char:燕子澜" target="chap:自动分块_44">
      <data key="d2">起初生气并拒绝顾绮尔的要求，但最终同意让她回房休息，显示出其性格上的温和一面。</data>
    </edge>
    <edge source="char:燕子澜" target="chap:自动分块_45">
      <data key="d2">起初拒绝了顾绮尔的要求，并让她回房休息。翌日，他没有立即回应顾绮尔关于修书房的请求。当晚，他在房间内</data>
    </edge>
    <edge source="char:燕子澜" target="chap:自动分块_46">
      <data key="d2">酒醉状态下试图对顾绮尔进行轻薄，但因顾绮尔的反抗而暂时停止；</data>
    </edge>
    <edge source="char:燕子澜" target="chap:自动分块_47">
      <data key="d2">随同顾绮尔前往外地治水患，对顾绮尔的行为表现出冷淡的态度。</data>
    </edge>
    <edge source="char:宜年" target="chap:自动分块_8">
      <data key="d2">太子的孩子，三、四岁左右，被顾绮尔提议带去偏殿休息。</data>
    </edge>
    <edge source="char:五皇子燕子澜" target="chap:自动分块_10">
      <data key="d2">出现并救下了顾绮尔和燕康白，随后离开，留下弓箭在手。</data>
    </edge>
    <edge source="char:颜惜筝" target="chap:自动分块_11">
      <data key="d2">在赏菊宴上与顾绮尔相遇，得知自己被顾绮尔挡了一剑的事情传到了她的耳朵里，因此对顾绮尔产生敌意，并表示</data>
    </edge>
    <edge source="char:琴贵妃" target="chap:自动分块_16">
      <data key="d2">对顾绮尔有意，并邀请她学习双面绣；留顾绮尔用膳并安排其休息。</data>
    </edge>
    <edge source="char:琴贵妃" target="chap:自动分块_17">
      <data key="d2">{"当前状态": "邀请顾绮尔去宁心殿喝茶并安排她午休；对燕子澜的行为感到困惑但又有些期待。"}</data>
    </edge>
    <edge source="char:琴贵妃" target="chap:自动分块_37">
      <data key="d2">{"当前状态": "在宁心殿与顾绮尔交谈，关心顾绮尔；位置\": \"宁心殿偏殿"}</data>
    </edge>
    <edge source="char:宋嬷嬷" target="chap:自动分块_16">
      <data key="d2">在宁心殿内，负责照顾琴贵妃和处理相关事宜。</data>
    </edge>
    <edge source="char:宋嬷嬷" target="chap:自动分块_17">
      <data key="d2">{"当前状态": "在宁心殿内负责照顾琴贵妃，处理相关事宜。"}</data>
    </edge>
    <edge source="char:傅情" target="chap:自动分块_22">
      <data key="d2">与翠荷勾搭成奸的事实被顾绮尘认出。</data>
    </edge>
    <edge source="char:傅情" target="chap:自动分块_23">
      <data key="d2">{"当前状态": "以补给为由扣住顾绮尔的手腕，并暗示有人欺负她；对顾绮尔的态度傲岸"}</data>
    </edge>
    <edge source="char:傅情" target="chap:自动分块_24">
      <data key="d2">作为梁国国师，他准备去见燕国皇帝，并在离开前给顾绮尔送了一个红漆雕花匣子。</data>
    </edge>
    <edge source="char:傅情" target="chap:自动分块_28">
      <data key="d2">为顾绮尔挑选灯笼和胭脂，带她逛市集，引导她找到初双和迎双，最后陪同她们上船。</data>
    </edge>
    <edge source="char:傅情" target="chap:自动分块_30">
      <data key="d2">闯入房间后与燕子澜交手，试图阻止二人争斗。</data>
    </edge>
    <edge source="char:傅情" target="chap:自动分块_31">
      <data key="d2">{"当前状态": "气愤地与顾绮尔争执", "位置": "房间内", "关系": "与顾绮尔的关系紧</data>
    </edge>
    <edge source="char:傅情" target="chap:自动分块_32">
      <data key="d2">试图与顾绮尔沟通昨晚之事，但遭到了顾绮尔的拒绝和不满。</data>
    </edge>
    <edge source="char:傅情" target="chap:自动分块_35">
      <data key="d2">{"当前状态": "出现威胁带走顾绮尔，并对顾绮尔的反应感到不满"}</data>
    </edge>
    <edge source="char:傅情" target="chap:自动分块_36">
      <data key="d2">{"当前状态": "因顾绮尔中毒而心生不满，试图用解药帮助她；位置\": \"在宫外马车上"}</data>
    </edge>
    <edge source="char:傅情" target="chap:自动分块_37">
      <data key="d2">{"当前状态": "在顾绮尔的房间安抚她；位置\": \"顾绮尔的房间"}</data>
    </edge>
    <edge source="char:凝夏" target="chap:自动分块_30">
      <data key="d2">与顾绮尔一同在房内，对顾绮尔的遭遇表示理解。</data>
    </edge>
    <edge source="char:小帮工" target="chap:自动分块_38">
      <data key="d2">{"当前状态": "被调离厨房并负责照看鲤鱼"}</data>
    </edge>
