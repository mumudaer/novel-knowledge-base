    <edge source="char:苏嘉" target="chap:第一章">
      <data key="d2">被系统君告知身份为大周王朝的新帝女帝苏嘉，内心充满矛盾与困惑，但已签订契约准备迎接新任务。</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第二章">
      <data key="d2">内心矛盾与困惑，准备完成男女平等的任务。</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第三章_分块1">
      <data key="d2">{"当前状态": "准备接近皇后未诞子的问题，并且在见兰羡白后打分给自己八十分"}</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第三章_分块2">
      <data key="d2">准备接近皇后未诞子的问题，并且在见兰羡白后打分给自己八十分；</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第四章">
      <data key="d2">骑射课上表现出色，被老师夸赞进步明显；与兰羡白发生争执后直接将兰贵妃赶走，并且未坐轿子返回；在雪地里</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第五章_分块1">
      <data key="d2">{"当前状态": "面对大选和冬猎事宜，保持冷静并考虑应对策略；与小统讨论治疗腿伤的方法"}</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第五章_分块2">
      <data key="d2">{"当前状态": "坚持要见兰羡白并提出冬猎随行嫔妃选任事宜，对兰羡白的厨艺表现出兴趣"}</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第六章">
      <data key="d2">陪伴在白清函身边，承诺不会嫌弃白清函身上的疤痕，并安慰她。</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第七章_分块1">
      <data key="d2">{"状态": "因担心白清函的伤势而感到焦虑；让宫人搬来了一个塌来给自己睡觉；对姬易霖表现出警惕"}</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第七章_分块2">
      <data key="d2">{"当前状态": "因担心白清函的伤势而感到焦虑，与姬易霖发生冲突后幸免于难", "位置": "云梦</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第八章_分块1">
      <data key="d2">{"当前状态": "带着怒气回到营帐", "位置": "云梦城内/与姬易霖发生冲突后幸免于难", "</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第八章_分块2">
      <data key="d2">{"当前状态": "站在雪地里，试图解释自己为何出现在这里", "位置": "云梦城内", "关系"</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第九章_分块1">
      <data key="d2">{"当前状态": "坐在雪地里，因体力不支和冻伤感到寒冷，但心系兰羡白的安全。"}</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第九章_分块2">
      <data key="d2">坐在雪地里，因体力不支和冻伤感到寒冷，但心系兰羡白的安全；在小统告知冬猎结束的消息后询问兰羡白的情况</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第十章_分块1">
      <data key="d2">{"当前状态": "坐在兰羡白床边用膳，试图通过亲近关系拉拢兰羡白成为自己的小弟，但遭拒绝；与兰羡白</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第十章_分块2">
      <data key="d2">坐在兰羡白床边，试图通过亲近拉拢成为其小弟</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第十一章_分块1">
      <data key="d2">在早朝上表现得轻松愉快，与臣子们互动频繁；通过各种方式逗乐了兰羡白，并试图用喂药的方式让她服下药物。</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第十一章_分块2">
      <data key="d2">正在泡澡，收到系统提示后感到恐慌，迅速穿上衣服并求助小统</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第十二章">
      <data key="d2">{"当前状态": "脸上有伤口，正在考虑如何处理与孟思睿的关系，并决定先见苏若琼"}</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第十三章">
      <data key="d2">{"当前状态": "好感值提升至40%，正在考虑如何投苏若琼所好"}</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第十四章">
      <data key="d2">{"当前状态": "因救了白清函而感到感激，对王璆鸣的态度冷淡"}</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第十五章">
      <data key="d2">因腿伤无法上朝，研究如何提高苏若琼好感值，与玉奴互动中了解其情况</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第十六章_分块1">
      <data key="d2">{"当前状态": "沉浸在震惊与怀疑中，对小统解释感到困惑和惊讶；面对玉奴时表现得有些紧张"}</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第十六章_分块2">
      <data key="d2">{"当前状态": "沉浸在震惊与怀疑中，对小统解释感到困惑和惊讶；"}</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第十七章">
      <data key="d2">{"当前状态": "一只猫，试图逃离王璆鸣的怀抱，并表现出对王璆鸣的不满和反抗"}</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第十八章">
      <data key="d2">{"当前状态": "亲自查看姬易霖病情，决定搜查青湘宫，并且命令恭理确保每个宫殿都保持同样的物资配备</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第十九章">
      <data key="d2">{"当前状态": "面对姬易霖的道歉感到困惑，并且在姬易霖念出情诗时被调戏反应强烈。"}</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第二十章_分块1">
      <data key="d2">在众人面前表现出对白清函的同情和理解，但内心可能有复杂的想法。</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第二十章_分块2">
      <data key="d2">决定跟随丝竹声前往离心湖边，试图看清黑衣人的面容，但因强风导致对面灯笼熄灭而无法看清对方全貌。</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第二十二章 （三合一）_分块1">
      <data key="d2">{"当前状态": "上早朝后讨论赈灾事宜", "位置": "御书房", "关系": "与苏若琼讨论赈</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第二十二章 （三合一）_分块2">
      <data key="d2">{"当前状态": "醉酒胡言乱语", "位置": "捕风楼", "关系": "除夕晚宴的主角, 误以</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第二十二章 （三合一）_分块3">
      <data key="d2">{"当前状态": "醉酒胡言乱语/捕风楼/除夕晚宴的主角，误以为敬王妃是他的嫂嫂"}</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第二十二章">
      <data key="d2">{"当前状态": "醉酒胡言乱语/捕风楼/除夕晚宴的主角，误以为敬王妃是他的嫂嫂"}</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第二十三章">
      <data key="d2">{"当前状态": "皇帝/除夕晚宴的主角", "位置": "与兰羡白同寝", "关系": "与兰羡白</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第二十四章">
      <data key="d2">{"当前状态": "了解了翎尾宫两位皇子的情况，并决定派人请他们过来；目睹了苏如温试图救出苏如越却意</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第二十五章">
      <data key="d2">前往汀雨殿留宿并与王璆鸣共寝，随后又去了敬王府，并对一出戏曲提出了质疑。在翎尾宫内发现了不寻常的声音</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第二十六章">
      <data key="d2">独自一人处理翎尾宫谋杀案后，前往姬易霖寝殿试探对方关系，并通过言语和行为控制姬易霖。在早膳时与姬易霖</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第二十七章">
      <data key="d2">在姬易霖寝殿用膳，身体出现异常反应，试图通过冷水缓解不适；与黑衣人对话后，命令周生通知女林军搜查宫殿</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第二十八章">
      <data key="d2">{"当前状态": "前往翎尾宫准备下，被挟持并灌药后解开身份之谜，发现白清函疲惫不堪"}</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第二十九章">
      <data key="d2">{"当前状态": "在翎尾宫上早朝，表现出不同于表面的平静；开始怀疑自己的身份；面对群臣的压力和提议</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第三十章">
      <data key="d2">在翎尾宫处理大选事宜，面对群臣压力和白清函的纠缠，决定让兰家小公子进宫为皇家开枝散叶。</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第三十一章">
      <data key="d2">{"当前状态": "处理姬美人病情，拒绝侍寝，安排太医诊治姬易霖，发现姬易霖因被握手受伤，对苏如越的</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第三十二章">
      <data key="d2">{"当前状态": "疲惫且困惑，对姬易霖和兰羡白的好感值问题感到不解；表情复杂，既有惊讶也有高兴"}</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第三十三章">
      <data key="d2">{"当前状态": "提议调整早朝时间并设立专门机构，与白宛玉交流后决定破坏二人秦晋之好"}</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第三十四章">
      <data key="d2">{"当前状态": "得知白清函哥哥进宫的消息后忐忑不安，与小统同行前往花灯市"}</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第三十五章">
      <data key="d2">跟随白清函在花灯市游玩，面对白清函的接近感到困惑和尴尬，藏匿胸垫未被发现。</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第36章">
      <data key="d2">被白清函表白后感到震惊并愤怒，最终咬伤了白清函。面对白清函的表白和争执，他显得有些不知所措。</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第37章">
      <data key="d2">回到皇宫后，对白清函的态度依然冷淡，但内心却因白清函的无辜而感到一丝同情。</data>
    </edge>
    <edge source="char:苏嘉" target="chap:第38章">
      <data key="d2">{"当前状态": "回到寝宫后情绪复杂，对新皇后和妃子表现出关心但也有疑虑；"}</data>
