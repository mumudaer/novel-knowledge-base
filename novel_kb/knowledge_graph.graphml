    <edge source="char:飞雁" target="chap:第62章">
      <data key="d2">{"当前状态": "因腹痛未能起床，正在家中休息。"}</data>
    </edge>
    <edge source="char:飞雁" target="chap:第71章">
      <data key="d2">{"当前状态": "跟随芝芝，担心大主子失踪；位置\": \"郊外宅邸", "关系": "与公主有求</data>
    </edge>
    <edge source="char:飞雁" target="chap:第72章">
      <data key="d2">{"当前状态": "担忧芝芝的状况/位置", "郊外宅邸/与芝芝有求于心；关系": "跟随芝芝"}</data>
    </edge>
    <edge source="char:飞雁" target="chap:第73章">
      <data key="d2">{"当前状态": "紧张焦虑", "位置": "前院", "关系": "跟随芝芝，持有刀"}</data>
    </edge>
    <edge source="char:飞雁" target="chap:第74章">
      <data key="d2">{"当前状态": "紧张焦虑", "位置": "前院", "关系": "跟随芝芝，持有刀"}</data>
    </edge>
    <edge source="char:云照师太" target="chap:第62章">
      <data key="d2">{"当前状态": "在慧溪寺内，对芝芝的身份感到困惑并询问。"}</data>
    </edge>
    <edge source="char:醋宝" target="chap:第79章">
      <data key="d2">{"当前状态": "早产儿，身体虚弱但活泼好动", "位置": "在床边", "关系": "由奶娘照</data>
    </edge>
    <edge source="char:醋宝" target="chap:第80章">
      <data key="d2">{"当前状态": "早产儿身体虚弱但活泼好动/在床边由奶娘照顾", "位置": "产房内", "关系</data>
    </edge>
    <edge source="char:醋宝" target="chap:第81章">
      <data key="d2">{"当前状态": "早产儿，身体虚弱但活泼好动；位置在景贞宫；关系密切与芝芝、裴信芳"}</data>
    </edge>
    <edge source="char:醋宝" target="chap:第84章">
      <data key="d2">{"当前状态": "被奶娘抱走；位置：未提及"}</data>
    </edge>
    <edge source="char:醋宝" target="chap:第87章">
      <data key="d2">{"当前状态": "被丢弃，但芝芝决定不丢弃", "位置": "未知", "关系": "被芝芝和裴信</data>
    </edge>
    <edge source="char:醋宝" target="chap:第90章 番外三">
      <data key="d2">六岁，智商和文化超过母亲芝芝，通过模仿太傅的字迹伪造了一封信来报复父亲裴信芳。他希望生一个妹妹以弥补</data>
    </edge>
    <edge source="char:奶娘方氏" target="chap:第79章">
      <data key="d2">{"当前状态": "正在照顾醋宝", "位置": "在房间内", "关系": "与芝芝和公主一起照顾</data>
    </edge>
    <edge source="char:裴信芳" target="chap:第80章">
      <data key="d2">{"当前状态": "当上皇帝并杀了很多人", "位置": "未知", "关系": "逼宫成功，但未杀</data>
    </edge>
    <edge source="char:裴信芳" target="chap:第81章">
      <data key="d2">{"当前状态": "新帝，对芝芝照顾醋宝表现出关心；位置在金銮殿；关系复杂与芝芝"}</data>
    </edge>
    <edge source="char:裴信芳" target="chap:第82章">
      <data key="d2">{"位置": "景贞宫", "关系": "太子伴读，与芝芝、醋宝有亲密关系；面对朝中反对册封仪式的奏</data>
    </edge>
    <edge source="char:裴信芳" target="chap:第83章">
      <data key="d2">{"当前状态": "将醋宝交给新晋状元郎向青雎当太傅；面对芝芝的质疑，显得无奈并认错"}</data>
    </edge>
    <edge source="char:裴信芳" target="chap:第84章">
      <data key="d2">{"当前状态": "对芝芝的梦境感到怀疑并要求她坦白所有秘密；位置：浴池殿"}</data>
    </edge>
    <edge source="char:裴信芳" target="chap:第85章">
      <data key="d2">{"当前状态": "愤怒、怀疑，离开时警告芝芝不要将实情告诉他人；位置\": \"龙椅上", "关系</data>
    </edge>
    <edge source="char:裴信芳" target="chap:第86章">
      <data key="d2">{"当前状态": "虚弱、病重，经常昏睡或盯着床帐，御医日夜守护；位置\": \"景贞宫/皇帝"}</data>
    </edge>
    <edge source="char:裴信芳" target="chap:第87章">
      <data key="d2">{"当前状态": "病重，仍未苏醒", "位置": "景贞宫/皇帝", "关系": "被芝芝照顾"}</data>
    </edge>
    <edge source="char:裴信芳" target="chap:第89章 番外二">
      <data key="d2">{"当前状态": "受伤康复中，前往西南赈灾途中遭遇难民暴动受伤，离魂时与鬼交易换取芝芝的心脏一半，</data>
    </edge>
    <edge source="char:裴信芳" target="chap:第90章 番外三">
      <data key="d2">因芝芝频繁无理要求和炫耀行为感到不满，试图哄骗芝芝放弃再生孩子的提议。目前在城墙上眺望远方秀丽景色。</data>
    </edge>
    <edge source="char:裴信芳" target="chap:第91章 番外四">
      <data key="d2">因不满芝芝与向青雎的关系而提出休书的要求，并在芝芝不妥协的情况下决定成为下堂夫。</data>
    </edge>
    <edge source="char:裴信芳" target="chap:第92章 番外五">
      <data key="d2">为了太子的大计，将一个看似无用的小妾纳为小妾，并且这个小妾怀孕。面对吕越阳的劝说，坚持要保留孩子。</data>
    </edge>
    <edge source="char:裴信芳" target="chap:第93章 番外六">
      <data key="d2">带着芝芝离开了京城，但没有放弃争取向青雎的机会。</data>
    </edge>
    <edge source="char:裴信芳" target="chap:第94章 番外七">
      <data key="d2">回到了永安三十一年的大婚首年，发现芝芝并未被他打死而是重活一世。他对芝芝的态度从冷漠转为亲近，并且两</data>
    </edge>
    <edge source="char:裴信芳" target="chap:第95章 番外八">
      <data key="d2">带芝芝去看戏，担心她受到打扰，但又想让芝芝感受到不同，内心独占欲强；与芝芝发生争执后决定将驸马赶走。</data>
    </edge>
    <edge source="char:裴信芳" target="chap:第96章 番外九">
      <data key="d2">内心独占欲强，对芝芝表现出亲近和关心，但也有着复杂的感情纠葛；</data>
    </edge>
    <edge source="char:吕越阳" target="chap:第82章">
      <data key="d2">{"位置": "未明确", "关系": "劝阻裴信芳册封芝芝为贵妃"}</data>
    </edge>
    <edge source="char:吕越阳" target="chap:第92章 番外五">
      <data key="d2">暂时监国的淮阴侯，得知三位小妾都求和离书离开，并且其中一位还与另一位女子在一起未嫁，陷入困惑。</data>
    </edge>
    <edge source="char:顾茂轩" target="chap:第82章">
      <data key="d2">{"位置": "未明确", "关系": "被邀请进宫筹措军费"}</data>
    </edge>
    <edge source="char:裴阅荛" target="chap:第83章">
      <data key="d2">{"当前状态": "作为皇叔的分担者，担忧前线士兵吃不上饭的问题"}</data>
    </edge>
    <edge source="char:裴阅荛" target="chap:第87章">
      <data key="d2">{"当前状态": "无", "位置": "未知", "关系": "偶遇芝芝"}</data>
    </edge>
