    <edge source="char:沈意" target="chap:第1章 第一章 婚约/暴风雨来临">
      <data key="d2">在花园里假装傻子，参加季家订婚典礼</data>
    </edge>
    <edge source="char:沈意" target="chap:第2章 第二章 情人合约">
      <data key="d2">在江遇房间中醒来，面对情人合约，内心挣扎，既想保护沈家人又不愿违背江遇意愿。</data>
    </edge>
    <edge source="char:沈意" target="chap:2.甲方可以任何时间结束合约，但乙方不能。">
      <data key="d2">{"当前状态": "被要求脱衣服，处于极度不安和恐惧中；位置在浴室里，面对江遇；关系上是江遇的受害者</data>
    </edge>
    <edge source="char:沈意" target="chap:第3章 第三章 用沐浴露当润滑剂/沈意被肏后穴">
      <data key="d2">{"当前状态": "被捆绑在浴室里，处于极度恐惧和痛苦中；位置在浴室里，面对江遇；关系上是江遇的受害</data>
    </edge>
    <edge source="char:沈意" target="chap:第4章 第四章 事后清洗">
      <data key="d2">被捆绑在浴室里，处于极度恐惧和痛苦中；全身软得厉害，意识清醒但身体无力；手臂被咬了一口，眼神警惕地看</data>
    </edge>
    <edge source="char:沈意" target="chap:第5章 第五章 “自己上来”/骑乘">
      <data key="d2">{"当前状态": "身体疼痛，尤其是后腰部位酸胀；内心担忧剧情变化；被迫坐下并感受到江遇的温暖气息；</data>
    </edge>
    <edge source="char:沈意" target="chap:第6章 第六章 接着骑乘/后入/主动">
      <data key="d2">{"身体状态": "全身酸痛、发红，臀部被多次打伤；精神状态：呆滞、眼神空洞"}</data>
    </edge>
    <edge source="char:沈意" target="chap:第7章 第七章 交易">
      <data key="d2">{"当前状态": "被带到华盛大楼休息室见到沈复生和苏婉容，对江遇的态度感到困惑"}</data>
    </edge>
    <edge source="char:沈意" target="chap:第8章 第八章  办公室play① 舔穴">
      <data key="d2">{"当前状态": "软瘫在床上，无力地趴在江遇两腿之间，面前正对江遇的裤裆；位置", "办公室内，躺</data>
    </edge>
    <edge source="char:沈意" target="chap:第9章 第九章 办公室play②办公桌下给江遇口交">
      <data key="d2">{"位置": "会议室下，被迫舔舐江遇的阴茎；随后被带回家中，处于极度紧张和恐惧的状态"}</data>
    </edge>
    <edge source="char:沈意" target="chap:第10章 第十章 破处">
      <data key="d2">处于极度痛苦与恐惧之中，身体湿透，精神崩溃，眼眶红肿，全身颤抖，紧闭双眼，泪流满面。</data>
    </edge>
    <edge source="char:沈意" target="chap:第11章 第十一章 陆延声/以擦药的名义摸穴">
      <data key="d2">{"当前状态": "身体湿透，精神崩溃，眼眶红肿，全身颤抖，紧闭双眼，泪流满面；位置在楼下等待江遇；</data>
    </edge>
    <edge source="char:沈意" target="chap:第12章 第十二章 宴会邀请/被肏生气">
      <data key="d2">{"当前状态": "身体湿透，精神崩溃，眼眶红肿，全身颤抖，紧闭双眼，泪流满面；在江遇办公室等待"}</data>
    </edge>
    <edge source="char:沈意" target="chap:第13章 第十三章 去宴会/季月">
