      <data key="d3">包含</data>
    </edge>
    <edge source="char:芝芝" target="chap:第1章">
      <data key="d2">被宫妈妈等人捉拿，被打死后化为阿飘，飘回原住处发现无人居住</data>
    </edge>
    <edge source="char:芝芝" target="chap:第2章">
      <data key="d2">在公主寝殿与小金龙对峙后，得知公主身份真相，试图接近公主了解家人下落，但被小金龙驱赶。最后决定用心脏</data>
    </edge>
    <edge source="char:芝芝" target="chap:第3章">
      <data key="d2">{"当前状态": "回到十五岁，与弟弟林元一起生活；决定嫁给向青雎作为探花郎的妻子；能看见阿飘"}</data>
    </edge>
    <edge source="char:芝芝" target="chap:第4章">
      <data key="d2">{"当前状态": "因被偷窥洗澡而惊吓晕过去，醒来后发现门外有罗妈和向青雎，内心矛盾。"}</data>
    </edge>
    <edge source="char:芝芝" target="chap:第5章">
      <data key="d2">因林父摔伤而焦急，决定送给向青雎一个荷包，并精心打扮前往向家。在与向青雎交谈时被后者拒之门外，内心矛</data>
    </edge>
    <edge source="char:芝芝" target="chap:第6章">
      <data key="d2">{"当前状态": "被阿飘附身，通过沈姐姐的描述得知姐姐芝芝借身体给沈姐姐探望阿覃的消息", "位置</data>
    </edge>
    <edge source="char:芝芝" target="chap:第7章">
      <data key="d2">{"当前状态": "被阿飘附身，在府邸内与林元、向青雎有亲属关系；对罗放婚事感到困扰"}</data>
    </edge>
    <edge source="char:芝芝" target="chap:第8章">
      <data key="d2">{"当前状态": "因罗放提亲而拒绝，并坦白心中已有意中人；煮茶给驸马及公主品尝；对向青雎的态度冷漠</data>
    </edge>
    <edge source="char:芝芝" target="chap:第9章">
      <data key="d2">{"当前状态": "感到挫败，对向青雎的态度更为敏感；佩戴珍珠以示身份"}</data>
    </edge>
    <edge source="char:芝芝" target="chap:第10章">
      <data key="d2">{"当前状态": "感到害怕和惊恐，忘记给向青雎送荷包，地位低且不爱出门"}</data>
    </edge>
    <edge source="char:芝芝" target="chap:第11章">
      <data key="d2">与向青雎、林元等人一起逛花灯节，发现了向青雎的一些小习惯，但她的荷包却不见踪影。</data>
    </edge>
    <edge source="char:芝芝" target="chap:第12章">
      <data key="d2">{"当前状态": "在向府门口遇见向青雎与女子的场景下感到困惑、失落和嫉妒；荷包上的鸳鸯让她想起自己</data>
    </edge>
    <edge source="char:芝芝" target="chap:第13章">
      <data key="d2">感到困惑、失落和嫉妒；被鬼魂纠缠后试图摆脱但未成功；拒绝了鬼魂的请求；对沈姐姐的建议表示赞同，并开始</data>
    </edge>
    <edge source="char:芝芝" target="chap:第14章">
      <data key="d2">{"当前状态": "清醒但困惑和恐惧，准备面对即将来临的婚姻；位置\": \"公主府翠钗院，作为驸马</data>
    </edge>
    <edge source="char:芝芝" target="chap:第15章">
      <data key="d2">{"当前状态": "害怕、困惑、疲惫；位置", "翠钗院作为五姨娘，与林元、采苓有交流；关系": "</data>
    </edge>
    <edge source="char:芝芝" target="chap:第16章">
      <data key="d2">{"当前状态": "害怕、疲惫、困惑", "位置": "公主寝殿", "关系": "正在经历侍疾过程</data>
    </edge>
    <edge source="char:芝芝" target="chap:第17章">
      <data key="d2">{"当前状态": "疲惫、困惑、害怕/位置", "翠钗院/关系": "公主侍疾"}</data>
    </edge>
    <edge source="char:芝芝" target="chap:第18章">
      <data key="d2">{"当前状态": "害怕、困惑、疲惫", "位置": "公主侍疾的病房", "关系": "前世夫君"</data>
    </edge>
    <edge source="char:芝芝" target="chap:第19章">
      <data key="d2">警惕、冷静、挣扎中</data>
    </edge>
    <edge source="char:芝芝" target="chap:第20章">
      <data key="d2">{"当前状态": "关禁闭一个月", "位置": "翠钗院", "关系": "公主府的五姨娘"}</data>
    </edge>
    <edge source="char:芝芝" target="chap:第21章">
