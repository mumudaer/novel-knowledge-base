    <edge source="char:姚绿衣" target="chap:自动分块_1">
      <data key="d2">正在享受花灯节的热闹氛围，准备与孟昀一起度过自己的十六岁生日。</data>
    </edge>
    <edge source="char:姚绿衣" target="chap:自动分块_2">
      <data key="d2">{"当前状态": "被父亲关在房中，准备嫁给城主"}</data>
    </edge>
    <edge source="char:姚青衣" target="chap:自动分块_1">
      <data key="d2">成功扮演了仙姑角色，受到全城百姓的关注和喜爱。</data>
    </edge>
    <edge source="char:姚青衣" target="chap:自动分块_2">
      <data key="d2">{"当前状态": "自杀身亡"}</data>
