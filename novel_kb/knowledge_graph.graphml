    </edge>
    <edge source="char:主角名2 (邬相庭)" target="chap:序言/前言">
      <data key="d2">阴柔外表下隐藏着复仇之心，与女主角霜霜（嘉宁）的关系复杂</data>
    </edge>
    <edge source="char:张生" target="chap:第1章">
      <data key="d2">{"当前状态": "头回来到金陵城芍金窟游玩，对这里的一切感到新奇和惊艳"}</data>
    </edge>
    <edge source="char:杜娘" target="chap:第1章">
      <data key="d2">{"当前状态": "芍金窟的老鸨，掌控着花娘的命运，对霜霜有控制欲"}</data>
    </edge>
    <edge source="char:杜娘" target="chap:第2章">
      <data key="d2">{"当前状态": "掌控着霜霜的命运，让其进行各种训练和接客。"}</data>
    </edge>
    <edge source="char:杜娘" target="chap:第4章">
      <data key="d2">{"当前状态": "试图讨好邬相庭，但面对他的厌恶感到尴尬；未直接参与冲突。"}</data>
    </edge>
    <edge source="char:杜娘" target="chap:第5章">
      <data key="d2">继续安排霜霜进入戏泉阁，表现出对霜霜的关注。,{"当前状态": "对霜霜进行严格训练和惩罚"}</data>
    </edge>
    <edge source="char:杜娘" target="chap:第7章">
      <data key="d2">{"当前状态": "忙碌，对霜霜严格要求和训练；位置", "芍金窟，监督霜霜的准备过程；关系": "</data>
    </edge>
    <edge source="char:杜娘" target="chap:第8章_分块1">
      <data key="d2">{"当前状态": "严厉警告霜霜，关系/霜霜的师傅"}</data>
    </edge>
    <edge source="char:杜娘" target="chap:第11章_分块1">
      <data key="d2">{"当前状态": "得知霜霜脸部受伤后试图安抚她，并让谢大夫为她治疗，但邬相庭的到来让她更加紧张。"</data>
    </edge>
    <edge source="char:杜娘" target="chap:第11章_分块2">
      <data key="d2">{"当前状态": "得知霜霜脸部受伤后试图安抚她，并让谢大夫帮忙处理伤口，但邬相庭的到来让她更加紧张</data>
    </edge>
    <edge source="char:霜霜" target="chap:第1章">
      <data key="d2">{"当前状态": "姜国公主嘉宁重生的花娘，身份特殊，被杜娘控制，渴望逃离"}</data>
    </edge>
    <edge source="char:霜霜" target="chap:第2章">
      <data key="d2">{"当前状态": "被杜娘控制在芍金窟进行花娘训练，渴望逃离这里，复国成功后要杀光所有侮辱她的敌人。</data>
    </edge>
    <edge source="char:霜霜" target="chap:第3章_分块1">
      <data key="d2">{"当前状态": "感到害怕和无助，试图隐藏自己的真实情感；位置：在戏泉阁帘子后面弹古琴；关系：被杜</data>
    </edge>
    <edge source="char:霜霜" target="chap:第3章_分块2">
      <data key="d2">在戏泉阁帘子后面弹古琴，位置隐蔽；感到害怕和无助，关系：被杜娘控制</data>
    </edge>
    <edge source="char:霜霜" target="chap:第4章">
      <data key="d2">{"当前状态": "在戏泉阁内，面对邬相庭的冷淡和杜娘的暗示感到极度不安；试图通过行礼来缓和气氛，但</data>
    </edge>
    <edge source="char:霜霜" target="chap:第5章">
      <data key="d2">因受到邬相庭和雪蚕的冷遇而感到不满和愤怒，但又对邬相庭产生了新的欲望。,{"当前状态": "愤怒、复杂、渴望摆脱现状"}</data>
    </edge>
    <edge source="char:霜霜" target="chap:第7章">
      <data key="d2">{"当前状态": "紧张、害怕、渴望逃离现状；位置", "芍金窟花船舱里；关系": "被邬相庭买下"</data>
    </edge>
    <edge source="char:霜霜" target="chap:第8章_分块1">
      <data key="d2">{"当前状态": "萎靡不振，脸色苍白，眼神空洞；位置/被邬相庭买下；关系/花娘"}</data>
    </edge>
    <edge source="char:霜霜" target="chap:第8章_分块2">
      <data key="d2">坐在邬相庭腿上，似乎喝了不少酒，脸色泛红，眼神迷离；位置：邬相庭房间内；关系：花娘</data>
    </edge>
    <edge source="char:霜霜" target="chap:第9章">
      <data key="d2">{"当前状态": "醉酒后坐在邬相庭腿上，手腕被捏红，内心既害怕又愤怒；位置：邬相庭房间内；关系：花</data>
    </edge>
    <edge source="char:霜霜" target="chap:第10章">
      <data key="d2">{"当前状态": "躺在床上，因病疼痛难忍；位置", "芍金窟内；关系": "花娘"}</data>
    </edge>
    <edge source="char:霜霜" target="chap:第11章_分块1">
      <data key="d2">{"当前状态": "脸被雪蚕打伤并用茶水泼过，试图通过下死手来吓唬连黛和杜娘，但邬相庭发现血迹后怀疑</data>
