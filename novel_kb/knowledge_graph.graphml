    <edge source="char:钱澈" target="chap:第三十章">
      <data key="d2">{"当前状态": "敏锐察觉到裴黎的异样，并与裴黎进行游戏互动"}</data>
    </edge>
    <edge source="char:钱澈" target="chap:第三十九章">
      <data key="d2">{"当前状态": "在电话中听到祁隐和裴黎的亲密行为，感到困惑；位置：家中"}</data>
    </edge>
    <edge source="char:钱澈" target="chap:第四十章_上半段">
      <data key="d2">{"当前状态": "通过短信了解情况", "位置": "家中", "关系": "对裴黎和祁隐的关系感</data>
    </edge>
    <edge source="char:钱澈" target="chap:第四十章_下半段">
      <data key="d2">{"当前状态": "通过短信了解情况", "位置": "家中", "关系": "与裴黎有间接交流"}</data>
    </edge>
    <edge source="char:钱澈" target="chap:第四十一章">
      <data key="d2">通过短信了解情况，未回复裴黎的询问。</data>
    </edge>
    <edge source="char:钱澈" target="chap:第五十章">
      <data key="d2">已经进门，与祁隐发生争执</data>
    </edge>
    <edge source="char:小花" target="chap:第三十章">
      <data key="d2">{"当前状态": "在游戏中帮助裴黎找到物资，与裴黎交流"}</data>
    </edge>
    <edge source="char:罗玉英" target="chap:第三十章">
      <data key="d2">{"当前状态": "在厨房为裴黎准备早饭，得知裴黎不去医院探望小姨夫"}</data>
    </edge>
    <edge source="char:罗玉英" target="chap:第三十七章">
      <data key="d2">在家为三人准备晚饭，并吩咐裴黎去买酱油。</data>
    </edge>
    <edge source="char:罗玉英" target="chap:第四十章_上半段">
      <data key="d2">{"当前状态": "带橙子去医院探望小姨夫", "位置": "医院病房", "关系": "与裴黎有亲</data>
    </edge>
    <edge source="char:罗玉英" target="chap:第四十章_下半段">
      <data key="d2">{"当前状态": "在家，与裴黎有亲密行为", "位置": "家中", "关系": "与裴黎有亲密行</data>
    </edge>
    <edge source="char:罗玉英" target="chap:第四十一章">
      <data key="d2">在厨房择菜，与裴黎互动，关心裴黎的情况。</data>
    </edge>
    <edge source="char:罗玉英" target="chap:第四十四章">
      <data key="d2">因裴闵知取消聚餐而感到不满，让裴黎去客厅玩，并告诉他祁隐想视频通话</data>
    </edge>
    <edge source="char:罗玉英" target="chap:第四十五章">
      <data key="d2">坐在客厅沙发旁，陪伴裴黎看春晚，并询问裴黎是否因为父亲离开而感到不高兴</data>
    </edge>
    <edge source="char:罗玉英" target="chap:第四十六章">
      <data key="d2">坐在客厅沙发旁陪伴裴黎看春晚，偶尔询问裴黎是否因为父亲离开而感到不高兴。</data>
    </edge>
    <edge source="char:罗玉英" target="chap:第四十七章">
      <data key="d2">坐在客厅沙发旁陪伴裴黎看春晚，偶尔询问裴黎是否因为父亲离开而感到不高兴。</data>
    </edge>
    <edge source="char:罗玉英" target="chap:第六十二章">
      <data key="d2">{"当前状态": "坚持要裴黎和祁隐回来处理问题；对裴黎的感情表示认可，但又提出让祁隐吃面的要求；"</data>
    </edge>
    <edge source="char:罗玉英" target="chap:第六十三章">
      <data key="d2">坚持要裴黎和祁隐回来处理问题；对裴黎的感情表示认可。</data>
    </edge>
    <edge source="char:沈韵" target="chap:第四十章_下半段">
      <data key="d2">{"当前状态": "在家，对裴黎和祁隐的关系感到困惑", "位置": "家中", "关系": "与裴</data>
    </edge>
    <edge source="char:祁隐的猫" target="chap:第五十二章">
      <data key="d2">被裴黎推走，但又凑到裴黎腿边喵喵叫。</data>
