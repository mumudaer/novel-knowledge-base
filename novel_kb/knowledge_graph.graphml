    <edge source="char:主角名1 (戚云维)" target="chap:自动分块_1">
      <data key="d2">因侄子戚子越的到来而感到不安，内心矛盾，既想出去玩又害怕哥哥戚沉昀的控制。</data>
    </edge>
    <edge source="char:主角名2 (戚子越)" target="chap:自动分块_1">
      <data key="d2">对姐姐戚云维的态度感到困惑和不满，试图通过送早餐来安抚她的情绪。</data>
    </edge>
    <edge source="char:戚云维" target="chap:自动分块_2">
      <data key="d2">{"当前状态": "在美国沙滩上，正经历着与戚沉昀之间的矛盾冲突；位置：美国沙滩；关系：被囚禁"}</data>
    </edge>
    <edge source="char:戚云维" target="chap:自动分块_3">
      <data key="d2">{"位置": "海边烧烤店", "关系": "与父亲发生争执"}</data>
    </edge>
    <edge source="char:戚云维" target="chap:自动分块_4">
      <data key="d2">逃离父亲家后，在海边沙滩上与美国男孩交谈，并试图通过手机联系自由。</data>
    </edge>
    <edge source="char:戚云维" target="chap:自动分块_5">
      <data key="d2">在花园找到逃跑方法后藏起黑色小包，并决定利用这个机会逃出戚家。虽然内心充满挣扎和恐惧，但她最终选择了</data>
    </edge>
    <edge source="char:戚云维" target="chap:自动分块_6">
      <data key="d2">{"当前状态": "逃离戚家，准备前往车站", "位置": "火车站候车厅", "关系": "正在逃</data>
    </edge>
    <edge source="char:戚云维" target="chap:自动分块_7">
      <data key="d2">{"当前状态": "搬出戚家，加入摇滚乐队，与哥哥戚沉昀关系紧张，最近频繁更换女伴"}</data>
    </edge>
    <edge source="char:戚云维" target="chap:自动分块_8">
      <data key="d2">{"当前状态": "参加宋三小姐生日派对，与吉吉等人一起处理安可、顾伽和自己被绑架的事情"}</data>
    </edge>
    <edge source="char:戚云维" target="chap:自动分块_9">
      <data key="d2">{"当前状态": "在家准备生日蛋糕", "位置": "家中厨房"}</data>
    </edge>
    <edge source="char:戚云维" target="chap:自动分块_10">
      <data key="d2">{"当前状态": "感到尴尬和困惑，试图避免与宋三小姐和戚子越的亲密接触，但又无法完全避开他们的互动</data>
    </edge>
    <edge source="char:戚云维" target="chap:自动分块_11">
      <data key="d2">{"当前状态": "感到震惊、尴尬和无奈，被迫留在浴室中"}</data>
    </edge>
    <edge source="char:戚云维" target="chap:自动分块_12">
      <data key="d2">{"当前状态": "决定继续排练乐队，但对旅行目的地感到困惑和不安"}</data>
    </edge>
