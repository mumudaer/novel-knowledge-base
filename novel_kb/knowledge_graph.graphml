    <edge source="char:裴黎" target="chap:第一章">
      <data key="d2">宅在家不愿出门，因室友邀请而外出吃饭，与室友韩末、陈于然一起吃了泡面。偶遇单恋对象祁隐，并在上色任务</data>
    </edge>
    <edge source="char:裴黎" target="chap:第二章">
      <data key="d2">{"当前状态": "因祁隐单恋陈于然而感到困扰，拒绝了祁隐邀请一起吃烤肉的提议，并在祁隐离开后继续留</data>
    </edge>
    <edge source="char:裴黎" target="chap:第三章">
      <data key="d2">{"当前状态": "逃离了祁隐的寝室，感到极度不安和羞耻；位置：校园外；关系：与祁隐处于对立状态"}</data>
    </edge>
    <edge source="char:裴黎" target="chap:第四章">
      <data key="d2">位置：宿舍内；当前状态：处于极度不安和羞耻中，试图通过回忆来平复心情，但大脑一片空白，无法想出应对之</data>
    </edge>
    <edge source="char:裴黎" target="chap:【7】：我明天上午也有课">
      <data key="d2">{"当前状态": "处于极度不安和羞耻中，试图通过回忆来平复心情，但大脑一片空白，无法想出应对之策；</data>
    </edge>
    <edge source="char:裴黎" target="chap:【7】：除此以外，没有其他的了">
      <data key="d2">处于极度不安和羞耻中，试图通过回忆来平复心情但大脑一片空白；位置：公共课教室靠窗倒数第二排的座位；关</data>
    </edge>
    <edge source="char:裴黎" target="chap:【7】：你好冷漠，我很认真在跟你说的">
      <data key="d2">{"当前状态": "处于极度不安和羞耻中，试图避免与祁隐联系；位置", "公共课教室靠窗倒数第二排的</data>
    </edge>
    <edge source="char:裴黎" target="chap:【7】：:p">
      <data key="d2">{"当前状态": "处于极度不安和羞耻中，试图避免与祁隐联系；位置/与祁隐处于对立状态"}</data>
    </edge>
    <edge source="char:裴黎" target="chap:第五章">
      <data key="d2">处于极度不安和羞耻中，试图避免与祁隐联系；位置/与祁隐处于对立状态</data>
    </edge>
    <edge source="char:裴黎" target="chap:【7】：摩西摩西？">
      <data key="d2">处于极度紧张和不安中，试图摆脱祁隐的控制，但在车里被强行带入并被迫参与性行为。</data>
    </edge>
    <edge source="char:裴黎" target="chap:第六章">
      <data key="d2">处于极度紧张和不安中，被强行带入车内并被迫参与性行为，身体上感到疼痛和不适，精神上受到强烈的心理压力</data>
    </edge>
    <edge source="char:裴黎" target="chap:第七章">
      <data key="d2">处于极度紧张和不安中，被强行带入车内并被迫参与性行为，身体上感到疼痛和不适，精神上受到强烈的心理压力</data>
    </edge>
    <edge source="char:裴黎" target="chap:第八章">
      <data key="d2">昏迷状态，被祁隐强行带入浴室进行性行为，身体和精神受到严重伤害，无法抵抗祁隐的控制。</data>
    </edge>
    <edge source="char:裴黎" target="chap:第九章">
      <data key="d2">清醒但仍处于昏迷状态的威胁下，身体和精神受到严重伤害，试图通过与祁隐对赌来摆脱纠缠，内心充满无力感。</data>
    </edge>
    <edge source="char:裴黎" target="chap:第十章">
      <data key="d2">在教学楼度过了一个迷幻的一天后决定回家休息，与室友韩末、陈于然一起吃夜宵。目前感到腰酸背痛，打算先回</data>
    </edge>
    <edge source="char:裴黎" target="chap:【7】：（图片）">
      <data key="d2">目前感到腰酸背痛，打算先回去睡一觉。,处于被动状态，尝试与祁隐建立边界，但仍对祁隐抱有一定的依赖感。</data>
    </edge>
    <edge source="char:裴黎" target="chap:【7】：？">
      <data key="d2">下午与陈于然一起前往教学楼，偶遇祁隐和秦毅庭，决定独自去见秦毅庭。</data>
    </edge>
    <edge source="char:裴黎" target="chap:【7】：乖乖，坐你对面的人是哪个逼？">
      <data key="d2">在教学楼偶遇钱澈和祁隐后，与祁隐对峙并注意到祁隐对面坐着一个男的。</data>
    </edge>
    <edge source="char:裴黎" target="chap:第十一章">
      <data key="d2">坐在教学楼内，面对祁隐，与钱澈交谈中。</data>
    </edge>
    <edge source="char:裴黎" target="chap:【7】：去厕所">
      <data key="d2">{"当前状态": "因元旦晚会未放烟花而感到失望和失落；关系上与祁隐的联系暂时中断"}</data>
    </edge>
    <edge source="char:裴黎" target="chap:第十二章">
      <data key="d2">被祁隐强行按在车内，身体紧闭，阴茎被插入体内，感受着强烈的性爱快感与痛苦；</data>
    </edge>
    <edge source="char:裴黎" target="chap:第十三章">
      <data key="d2">被祁隐按在车内，身体紧闭，处于被动状态；试图反抗但无法摆脱束缚，身体因性爱而紧绷，情绪波动大。</data>
    </edge>
    <edge source="char:裴黎" target="chap:第十四章">
      <data key="d2">处于被动状态，情绪复杂，试图反抗但无法摆脱束缚；</data>
    </edge>
    <edge source="char:裴黎" target="chap:【7】：要是不回，我能来找你玩吗？">
      <data key="d2">处于被动状态，尝试与祁隐建立边界，但仍对祁隐抱有一定的依赖感。在本章中，裴黎没有立即答应祁隐的邀请，</data>
    </edge>
    <edge source="char:裴黎" target="chap:【7】：你一call">
      <data key="d2">处于被动状态，继续拒绝祁隐的邀请，并因女友提示而承认自己单身，面对陈于然的抱怨表现出无奈。</data>
    </edge>
    <edge source="char:裴黎" target="chap:第十五章">
      <data key="d2">躺在床上，脖子上搭着毛巾，正在处理手机上的信息</data>
    </edge>
    <edge source="char:裴黎" target="chap:【7】：早点睡">
      <data key="d2">躺在床上，脖子上搭着毛巾，正在处理手机上的信息，同时感受到祁隐语音中的亲密暗示，耳朵因紧张而微红。</data>
    </edge>
    <edge source="char:裴黎" target="chap:【7】：我的晚安">
      <data key="d2">躺在床上处理手机上的信息，耳朵因紧张而微红，脖子上搭着毛巾。</data>
    </edge>
    <edge source="char:裴黎" target="chap:【7】：好哦，晚安">
      <data key="d2">躺在床上处理手机上的信息，耳朵因紧张而微红，脖子上搭着毛巾</data>
    </edge>
    <edge source="char:裴黎" target="chap:【7】：高兴???">
      <data key="d2">{"当前状态": "躺在床上处理手机上的信息，耳朵因紧张而微红，脖子上搭着毛巾"}</data>
    </edge>
    <edge source="char:裴黎" target="chap:【7】：我问你，你跟你对象第一次约会都去哪里？">
      <data key="d2">醒得很晚，从床帘里探出头查看时间11:48，得知陈于然和韩末已离开后，立即联系祁隐确认位置，并在公寓</data>
    </edge>
    <edge source="char:裴黎" target="chap:【7】：我刚到">
      <data key="d2">与祁隐一起前往餐馆并预订了情侣观影的座位，但对陌生男子的存在感到困惑和不安。</data>
    </edge>
    <edge source="char:裴黎" target="chap:第十六章">
      <data key="d2">{"当前状态": "对祁隐的亲密行为表现出抗拒和紧张，观影过程中拒绝牵手；走出影院后仍牵着手，但内心</data>
    </edge>
    <edge source="char:裴黎" target="chap:第十七章">
      <data key="d2">{"当前状态": "玩得开心，但内心有些困惑；对祁隐的行为感到好奇和抗拒"}</data>
    </edge>
    <edge source="char:裴黎" target="chap:第十八章">
      <data key="d2">{"当前状态": "处于极度敏感和痛苦之中，被祁隐紧紧控制着；内心充满矛盾和挣扎"}</data>
    </edge>
    <edge source="char:裴黎" target="chap:第十九章">
      <data key="d2">{"当前状态": "极度敏感和痛苦，身体充满矛盾和挣扎；被祁隐紧紧控制在怀里"}</data>
    </edge>
    <edge source="char:裴黎" target="chap:第二十章">
      <data key="d2">{"当前状态": "身体被牢牢控制在床铺上，只能被动承受痛苦；反应强烈但无力反抗；精神混乱，感觉全身</data>
    </edge>
    <edge source="char:裴黎" target="chap:第二十一章">
      <data key="d2">昏睡中，试图反抗并最终成功入睡；脸上有轻微的红肿和眼尾的红晕，眼神温柔而安静。</data>
    </edge>
    <edge source="char:裴黎" target="chap:【7】：明天播">
      <data key="d2">昏睡中，试图反抗但最终成功入睡，脸上有轻微的红肿和眼尾的红晕，眼神温柔而安静。</data>
    </edge>
    <edge source="char:裴黎" target="chap:【7】：别管">
      <data key="d2">昏睡中，脸上有轻微的红肿和眼尾的红晕，眼神温柔而安静。</data>
    </edge>
    <edge source="char:裴黎" target="chap:【7】：无">
      <data key="d2">{"当前状态": "昏睡中，额头滚烫，鼻塞，疑似发烧"}</data>
    </edge>
    <edge source="char:裴黎" target="chap:38.6度。">
      <data key="d2">昏睡中，额头滚烫，鼻塞，疑似发烧；在梦中与裴闵知对话，感到困惑和愤怒；哭泣后情绪激动，身体感觉冷且不</data>
    </edge>
    <edge source="char:裴黎" target="chap:第二十二章">
      <data key="d2">{"当前状态": "昏睡醒来后情绪低落，身体不适；在洗澡过程中与祁隐发生了亲密接触，但对祁隐的行为感</data>
