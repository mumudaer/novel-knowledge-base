    <edge source="char:虞亦青" target="chap:序言/前言">
      <data key="d2">当前处于与大美人的相遇之中，对大美人所展示的内容充满好奇。</data>
    </edge>
    <edge source="char:虞亦青" target="chap:第1章 失忆症（一）">
      <data key="d2">{"当前状态": "昏迷后被梅初蔚救醒，身体虚弱，无法动弹；意识模糊中看到梅初蔚和温藻"}</data>
    </edge>
    <edge source="char:虞亦青" target="chap:第2章 失忆症（二）">
      <data key="d2">{"当前状态": "昏迷后被救醒，身体虚弱，无法动弹；意识模糊中看到梅初蔚和温藻"}</data>
    </edge>
    <edge source="char:虞亦青" target="chap:第3章 失忆症（三）">
      <data key="d2">{"当前状态": "昏迷后被救醒，身体虚弱，无法动弹；意识模糊"}</data>
    </edge>
    <edge source="char:虞亦青" target="chap:第4章 失忆症（四）">
      <data key="d2">{"当前状态": "昏迷后被救醒，身体虚弱，无法动弹；意识模糊"}</data>
    </edge>
    <edge source="char:虞亦青" target="chap:第5章 失忆症（五）">
      <data key="d2">{"当前状态": "昏迷后被救醒，身体虚弱，无法动弹；意识模糊"}</data>
    </edge>
    <edge source="char:虞亦青" target="chap:第6章 失忆症（六）">
      <data key="d2">{"当前状态": "昏迷后被救醒，身体虚弱，无法动弹；意识模糊"}</data>
    </edge>
    <edge source="char:虞亦青" target="chap:第7章 失忆症（七）">
      <data key="d2">{"当前状态": "昏迷后被救醒，身体虚弱，无法动弹；意识模糊"}</data>
    </edge>
    <edge source="char:虞亦青" target="chap:第8章 失忆症（八）">
      <data key="d2">昏迷未醒，身体虚弱，无法动弹</data>
    </edge>
    <edge source="char:虞亦青" target="chap:第12章 失忆症（十二）">
      <data key="d2">浑身无力，被温藻控制和脱衣受罚。恢复记忆后依然保持冷漠的态度。</data>
    </edge>
    <edge source="char:虞亦青" target="chap:第13章 失忆症（十三）">
      <data key="d2">{"当前状态": "浑身无力，遭受虐待，失去记忆，但依然保持冷漠的态度"}</data>
    </edge>
    <edge source="char:虞亦青" target="chap:第14章 失忆症（十四）">
      <data key="d2">浑身无力，遭受虐待，失去记忆，保持冷漠</data>
    </edge>
    <edge source="char:虞亦青" target="chap:第15章 失忆症（十五）">
      <data key="d2">昏迷状态，被包裹在被子里，对周围环境感到陌生和不安。</data>
    </edge>
    <edge source="char:虞亦青" target="chap:第16章 失忆症（十六）">
      <data key="d2">昏迷状态，被包裹在被子里，对周围环境感到陌生和不安。后被温藻、尤亭旭等人挟持，被迫与之发生性行为。逃</data>
    </edge>
    <edge source="char:虞亦青" target="chap:第17章 失忆症（十七）">
      <data key="d2">昏迷后醒来，身体虚弱且内力中毒，被迫与荷旖同行前往东厂；</data>
    </edge>
    <edge source="char:虞亦青" target="chap:第18章 失忆症（十八）">
      <data key="d2">身体虚弱且内力中毒，被迫与荷旖同行前往东厂；试图通过购买草药来掩饰脸上的易容；在医馆看病并买药时表现</data>
    </edge>
    <edge source="char:虞亦青" target="chap:第19章 失忆症（十九）">
      <data key="d2">{"当前状态": "疲惫但冷静，决定暂时以林陵的身份行动；已沐浴完毕，准备继续赶路"}</data>
    </edge>
    <edge source="char:虞亦青" target="chap:第20章 失忆症（二十）">
      <data key="d2">疲惫但冷静，决定暂时以林陵的身份行动；已沐浴完毕，准备继续赶路；与荷旖发生争执后，坚持不让对方开口嘲</data>
    </edge>
    <edge source="char:虞亦青" target="chap:第21章 失忆症（二十一）">
      <data key="d2">{"当前状态": "独自赶往京城，心思缜密，已夺走了解药；位置：前往京城途中", "关系": "与荷</data>
    </edge>
    <edge source="char:虞亦青" target="chap:第22章 失忆症（二十二）">
      <data key="d2">被温藻用匕首刺伤，双手双脚被绳子绑着，位置：土地神庙内，与温藻有矛盾</data>
    </edge>
    <edge source="char:虞亦青" target="chap:第23章 第二十三章">
      <data key="d2">{"当前状态": "被绑并反抗，伤口止血但衣服染红；位置：土地神庙内；关系\": \"与温藻有矛盾"</data>
    </edge>
    <edge source="char:虞亦青" target="chap:第24章 第二十四章">
      <data key="d2">在马车上与温藻发生亲密行为后，感到不安和警惕；对香囊的味道产生怀疑；在城中被人撞到时表现出紧张和不悦</data>
    </edge>
    <edge source="char:虞亦青" target="chap:第25章 第二十五章">
      <data key="d2">在城中被人撞到时表现出紧张和不悦，与温藻发生了亲密行为后，对温藻的威胁显得更加坚定；</data>
    </edge>
    <edge source="char:虞亦青" target="chap:第26章 第二十六章">
      <data key="d2">在暗道中与义父相遇，跪地求救；</data>
    </edge>
    <edge source="char:虞亦青" target="chap:第27章 晋江独家发表">
      <data key="d2">{"当前状态": "在暗道中被房宾白救起，随后被安排乘坐软轿前往目的地，并用膳；目前正接受房宾白的惩</data>
    </edge>
    <edge source="char:虞亦青" target="chap:第28章 晋江独家发表">
      <data key="d2">被送入秘密池子接受三天惩罚后醒来，面对房宾白和谷毓的对话表现出沉默寡言的态度，内心对当前处境感到困惑</data>
    </edge>
    <edge source="char:虞亦青" target="chap:第29章 晋江独家发表">
      <data key="d2">被谷毓安排在亭子里玩猜数游戏，对谷毓的真实身份和动机感到困惑和不安。</data>
    </edge>
    <edge source="char:虞亦青" target="chap:第30章 晋江独家发表">
      <data key="d2">被要求一个月不得出府，跟随谷毓处理城中的断头案，偷听了容毓和容贵妃的对话，了解了谷毓的真实身份和关系</data>
    </edge>
    <edge source="char:虞亦青" target="chap:第31章 晋江独家发表">
      <data key="d2">{"当前状态": "在暗河中挣扎求生", "位置": "暗河", "关系": "谷毓的助手"}</data>
    </edge>
    <edge source="char:虞亦青" target="chap:第32章 晋江独家发表">
      <data key="d2">在府邸保护谷毓，并提出获取锦衣卫指挥使温藻的资料和继续破案的要求。</data>
    </edge>
    <edge source="char:虞亦青" target="chap:第33章 晋江独家发表">
      <data key="d2">秘密进入温藻住所并发现其秘密，准备将这些信息带回，并故意破坏花瓶以引起注意。当前在寻找线索的途中。</data>
    </edge>
    <edge source="char:虞亦青" target="chap:第34章 晋江独家发表">
      <data key="d2">在妾室父母家观察，并未发现异常；随后前往将军府外查看，但无法进入；与谷毓讨论案件进展。</data>
    </edge>
    <edge source="char:虞亦青" target="chap:第35章 晋江独家发表">
      <data key="d2">继续调查威武大将军府小妾之死案，对案件细节进行分析；被房宾白指派调查十二皇子的背景，但决定先不杀他，</data>
    </edge>
    <edge source="char:虞亦青" target="chap:第36章 晋江独家发表">
      <data key="d2">继续调查威武大将军府小妾之死案，同时深入调查十二皇子的背景。在栾山殿与十二皇子见面时，发现对方是个瞎</data>
    </edge>
    <edge source="char:虞亦青" target="chap:第37章 晋江独家发表">
      <data key="d2">在望鲲楼顶层与十二皇子交谈，发现对方失明后仍礼貌接受点心并表示感谢。得知十二皇子曾是姜国质子十五年后</data>
    </edge>
    <edge source="char:虞亦青" target="chap:第38章 晋江独家发表">
      <data key="d2">被逼至绝境，身体虚弱，青丝散落一床，眼睛红肿，透着粉；</data>
    </edge>
    <edge source="char:虞亦青" target="chap:第39章 晋江独家发表">
      <data key="d2">身体恢复了一些力气，但仍虚弱；在穆旦的监视下，与房宾白（瑞王）关系微妙；对瑞王的态度从警惕到好奇转变</data>
    </edge>
